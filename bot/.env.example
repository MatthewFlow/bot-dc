# ── API ────────────────────────────────────────────────────────────
# Port on which the Hono REST API will listen
API_PORT=3001

# Secret token for API authorization via "Authorization: Bearer <token>"
# Leave empty to disable auth and make the API publicly accessible
API_TOKEN=

# ── DISCORD ────────────────────────────────────────────────────────
# Bot token from Discord Developer Portal → Bot → Reset Token
DISCORD_TOKEN=

# ── SERVER ─────────────────────────────────────────────────────────
# ID of your Discord server (right-click server icon → Copy ID)
GUILD_ID=

# ID of the role required to use /cfg_* and /test_* commands
CFG_ADMIN_ROLE_ID=

# ── CHANNELS ───────────────────────────────────────────────────────
# Fallback channel IDs — these are used if not set via /cfg_* commands
# Right-click a channel → Copy ID to get the ID

# Channel where welcome messages are sent on member join
WELCOME_CHANNEL_ID=

# Channel where farewell messages are sent on member leave
GOODBYE_CHANNEL_ID=

# Channel where level-up notifications are sent
LEVEL_UP_CHANNEL_ID=

# Debug — set to true to clear and re-register slash commands, then set back to false
RESET_COMMANDS=