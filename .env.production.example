# ════════════════════════════════════════════════════════════════════════════
#  Produkcja (docker-compose). Skopiuj do `.env` i uzupełnij:
#      cp .env.production.example .env
#  Plik `.env` jest w .gitignore — NIE commituj go.
# ════════════════════════════════════════════════════════════════════════════

# ── ADRES / HTTPS ───────────────────────────────────────────────────────────
# CADDY_SITE  = adres, na którym Caddy serwuje (host => auto‑HTTPS, ":80" => sam HTTP)
# PUBLIC_URL  = pełny publiczny URL panelu (z http:// lub https://)
# COOKIE_SECURE = czy ciasteczko logowania ma flagę Secure (true wymaga HTTPS)
#
# ── WARIANT A: masz domenę (zalecane) ─────────────────────
#   CADDY_SITE=twojadomena.pl
#   PUBLIC_URL=https://twojadomena.pl
#   COOKIE_SECURE=true
#
# ── WARIANT B: bez domeny, ale HTTPS przez darmowe nip.io (ZALECANE dla VPS bez domeny) ──
#   Zamień kropki w IP na myślniki: IP 203.0.113.5  ->  203-0-113-5.nip.io
#   CADDY_SITE=203-0-113-5.nip.io
#   PUBLIC_URL=https://203-0-113-5.nip.io
#   COOKIE_SECURE=true
#
# ── WARIANT C: samo IP po HTTP (szybki podgląd; LOGOWANIE mniej bezpieczne) ──
#   CADDY_SITE=:80
#   PUBLIC_URL=http://203.0.113.5
#   COOKIE_SECURE=false
#
CADDY_SITE=203-0-113-5.nip.io
PUBLIC_URL=https://203-0-113-5.nip.io
COOKIE_SECURE=true

# ── BAZA DANYCH ─────────────────────────────────────────────────────────────
# Domyślnie kontener „mongo" z compose. Dla MongoDB Atlas wpisz pełny URI
# (mongodb+srv://...) i usuń/zatrzymaj usługę „mongo".
MONGODB_URI=mongodb://mongo:27017/jurassic_haven

# ── AUTH ────────────────────────────────────────────────────────────────────
# Sekret podpisujący JWT — min. 32 losowe znaki. Wygeneruj:  openssl rand -hex 32
JWT_SECRET=

# ── DISCORD ─────────────────────────────────────────────────────────────────
# Developer Portal → Bot → Reset Token
DISCORD_TOKEN=
# Developer Portal → OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# WAŻNE: w Developer Portal → OAuth2 → Redirects dodaj DOKŁADNIE wartość:
#   <PUBLIC_URL>/api/auth/callback
#   np. https://203-0-113-5.nip.io/api/auth/callback   albo   http://203.0.113.5/api/auth/callback

# ── SERWER / KANAŁY (bot) ───────────────────────────────────────────────────
# ID serwera, na którym rejestrowane są komendy (kliknij PPM na ikonę → Kopiuj ID)
GUILD_ID=
# Zapasowa rola admina do /cfg_* /mod_* (lepiej: uprawnienie Administrator / rola z panelu)
CFG_ADMIN_ROLE_ID=
# Zapasowe kanały — nadpisywane przez konfigurację z panelu/komend
WELCOME_CHANNEL_ID=
GOODBYE_CHANNEL_ID=
LEVEL_UP_CHANNEL_ID=

# Ustaw na „true" JEDNORAZOWO, by wyczyścić i przerejestrować komendy; potem z powrotem „false".
RESET_COMMANDS=false
