# ════════════════════════════════════════════════════════════════════════════
#  Produkcja (docker-compose). Skopiuj do `.env` i uzupełnij:
#      cp .env.production.example .env
#  Plik `.env` jest w .gitignore — NIE commituj go.
# ════════════════════════════════════════════════════════════════════════════

# ── DOMENA ──────────────────────────────────────────────────────────────────
# Domena wskazująca na ten VPS (rekord A w DNS). Caddy automatycznie wystawi HTTPS.
# Z niej compose wyprowadza PANEL_URL, DISCORD_REDIRECT_URI i CORS_ORIGINS.
# Do lokalnego testu bez domeny: DOMAIN=:80 (bez HTTPS — logowanie nie zadziała).
DOMAIN=twojadomena.pl

# ── BAZA DANYCH ─────────────────────────────────────────────────────────────
# Domyślnie kontener „mongo" z compose. Dla MongoDB Atlas wpisz pełny URI
# (mongodb+srv://...) i usuń/zatrzymaj usługę „mongo".
MONGODB_URI=mongodb://mongo:27017/jurassic_haven

# ── AUTH ────────────────────────────────────────────────────────────────────
# Sekret podpisujący JWT — min. 32 losowe znaki. Wygeneruj:  openssl rand -hex 32
JWT_SECRET=

# ── DISCORD ─────────────────────────────────────────────────────────────────
# Developer Portal → Bot → Reset Token
DISCORD_TOKEN=
# Developer Portal → OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# WAŻNE: w Developer Portal → OAuth2 → Redirects dodaj DOKŁADNIE:
#   https://twojadomena.pl/api/auth/callback

# ── SERWER / KANAŁY (bot) ───────────────────────────────────────────────────
# ID serwera, na którym rejestrowane są komendy (kliknij PPM na ikonę → Kopiuj ID)
GUILD_ID=
# Zapasowa rola admina do /cfg_* /mod_* (lepiej: uprawnienie Administrator / rola z panelu)
CFG_ADMIN_ROLE_ID=
# Zapasowe kanały — nadpisywane przez konfigurację z panelu/komend
WELCOME_CHANNEL_ID=
GOODBYE_CHANNEL_ID=
LEVEL_UP_CHANNEL_ID=

# Ustaw na „true" JEDNORAZOWO, by wyczyścić i przerejestrować komendy; potem z powrotem „false".
RESET_COMMANDS=false
