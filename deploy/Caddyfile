# Reverse proxy. {$CADDY_SITE} ze zmiennej środowiskowej kontenera Caddy:
#   - domena/host (np. twojadomena.pl lub 203-0-113-5.nip.io) => automatyczny HTTPS (Let's Encrypt)
#   - ":80"                                                    => sam HTTP (VPS na samym IP, bez domeny)
# HTTPS wymaga hosta wskazującego na IP VPS + otwartych portów 80 i 443.

{$CADDY_SITE} {
	encode gzip

	# API: /api/* → kontener api (prefiks /api jest usuwany przez handle_path)
	handle_path /api/* {
		reverse_proxy api:3002
	}

	# Panel (Next.js): cała reszta ruchu
	handle {
		reverse_proxy panel:3000
	}
}

# ── Tryb bez domeny (sam IP) ─────────────────────────────────────────────────
# W .env: CADDY_SITE=:80, PUBLIC_URL=http://IP_VPS, COOKIE_SECURE=false.
# UWAGA: po HTTP logowanie działa tylko z COOKIE_SECURE=false (mniej bezpieczne).
# Zalecane mimo braku domeny: użyj hosta <IP-z-myślnikami>.nip.io → darmowy HTTPS.
