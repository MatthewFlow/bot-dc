{
  "name": "jurassic-haven",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter './apps/*' dev",
    "bot": "cd apps/bot && bun run start",
    "api": "cd apps/api && bun run start",
    "panel": "cd apps/panel && bun run dev",
    "test": "bun test",
    "typecheck": "bunx tsc -p packages/db/tsconfig.json && bunx tsc --noEmit -p apps/bot/tsconfig.json && bunx tsc --noEmit -p apps/api/tsconfig.json && bunx tsc --noEmit -p apps/panel/tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "^3.9.1",
    "typescript-eslint": "^8.62.0"
  },
  "dependencies": {
    "@types/node": "^26.0.1"
  }
}
