# ── API ────────────────────────────────────────────────────────────
# Port on which the Hono REST API will listen
API_PORT=3002

# ── DATABASE ───────────────────────────────────────────────────────
# MongoDB connection string (shared with the bot)
MONGODB_URI=mongodb://localhost:27017/jurassic-haven

# ── DISCORD ────────────────────────────────────────────────────────
# Bot token — the API proxies channel/role/leaderboard/stats requests with it
DISCORD_TOKEN=

# OAuth2 credentials from Discord Developer Portal → OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Must match a redirect URL added in Discord Developer Portal → OAuth2
DISCORD_REDIRECT_URI=http://localhost:3002/auth/callback

# Base URL of the panel app — used for the OAuth2 callback redirect and as a
# fallback CORS origin
PANEL_URL=http://localhost:3000

# ── CORS / PROXY ───────────────────────────────────────────────────
# Comma-separated list of allowed browser origins (falls back to PANEL_URL,
# then http://localhost:3000)
CORS_ORIGINS=http://localhost:3000

# Set to true when running behind a reverse proxy so the rate limiter trusts
# the X-Forwarded-For header for the client IP
TRUST_PROXY=false

# Set to true to force the Secure flag on the auth cookie (auto-on in
# production). Leave false for plain-HTTP local dev.
COOKIE_SECURE=false

# ── AUTH ───────────────────────────────────────────────────────────
# Secret key for signing JWTs — use at least 32 random characters
JWT_SECRET=
