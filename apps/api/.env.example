# ── API ────────────────────────────────────────────────────────────
# Port on which the Hono REST API will listen
API_PORT=3002

# ── DATABASE ───────────────────────────────────────────────────────
# MongoDB connection string
MONGODB_URI=

# ── DISCORD OAUTH2 ─────────────────────────────────────────────────
# Application Client ID from Discord Developer Portal → OAuth2
DISCORD_CLIENT_ID=

# Application Client Secret from Discord Developer Portal → OAuth2
DISCORD_CLIENT_SECRET=

# Must match the redirect URL added in Discord Developer Portal → OAuth2
DISCORD_REDIRECT_URI=http://localhost:3002/auth/callback

# Base URL of the panel app — used for OAuth2 callback redirect
PANEL_URL=http://localhost:3000

# ── AUTH ───────────────────────────────────────────────────────────
# Secret key for signing JWT tokens — generate a random string
JWT_SECRET=