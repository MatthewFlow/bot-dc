# ── DATABASE ───────────────────────────────────────────────────────
# MongoDB connection string (shared with the API)
MONGODB_URI=mongodb://localhost:27017/jurassic-haven

# ── DISCORD ────────────────────────────────────────────────────────
# Bot token from Discord Developer Portal → Bot → Reset Token
DISCORD_TOKEN=

# ── SERVER ─────────────────────────────────────────────────────────
# ID of your Discord server (right-click server icon → Copy ID).
# Only used to clear stale guild-scoped commands on reset; commands
# are registered globally.
GUILD_ID=

# Legacy fallback admin role for /cfg_*, /mod_*, /test_* and ticket setup.
# Prefer the native Administrator permission or a per-guild admin role set
# from the dashboard.
CFG_ADMIN_ROLE_ID=

# Base URL of the panel — used in the onboarding intro message posted when
# the bot joins a new server (default: http://localhost:3000)
PANEL_URL=http://localhost:3000

# ── DEBUG ──────────────────────────────────────────────────────────
# Set to true to clear and re-register slash commands on next startup,
# then set back to false after the bot starts.
RESET_COMMANDS=false

# ── OBSERVABILITY (optional) ──────────────────────────────────────
# Sentry DSN — error reporting. Leave empty to disable (no-op).
SENTRY_DSN=
